{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@bookscanner/shared": ["packages/shared/src"],
      "@bookscanner/shared/*": ["packages/shared/src/*"],
      "@bookscanner/ocr-processor": ["packages/ocr-processor/src"],
      "@bookscanner/ocr-processor/*": ["packages/ocr-processor/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
